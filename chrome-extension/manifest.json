{
  "manifest_version": 3,
  "name": "LeadMed — IndiaMART Lead Capture",
  "version": "2.0.0",
  "description": "Capture leads directly from IndiaMART seller panel and send to your LeadMed dashboard.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeadMed — IndiaMART Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://seller.indiamart.com/*"],
      "js": ["content.js"],
      "css": ["content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "cookies",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://seller.indiamart.com/*",
    "http://localhost:3001/*",
    "https://*.onrender.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://seller.indiamart.com/*"]
    }
  ],
  "options_page": "options.html"
}
